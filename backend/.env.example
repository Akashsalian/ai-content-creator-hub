# ── Copy this file to .env and fill in your values ──

# Groq API Key — get from console.groq.com
GROQ_API_KEY=key_goes_here

# MongoDB — get free cluster from mongodb.com/atlas
MONGO_URI=mongodburllll

JWT_SECRET=change_this_to_a_very_long_random_secret_string_123456

# JWT expiry in minutes
ACCESS_TOKEN_EXPIRE_MINUTES=1440


FRONTEND_URL=*
